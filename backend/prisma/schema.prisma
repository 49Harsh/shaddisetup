generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  phone           String            @unique @default("")
  email           String?           @unique
  full_name       String            @default("")
  role            Role              @default(user)
  village         String?
  block           String            @default("")
  district        String            @default("")
  pincode         String            @default("")
  profile_photo   String?
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin           Admin?
  orders          orders[]
  vendor          Vendor?
  service_ratings service_ratings[]

  @@map("users")
}

model Vendor {
  business_name    String
  service_types    String[]          @default([])
  experience_years Int?
  experience_desc  String            @default("")
  working_hours    String            @default("9 AM - 8 PM")
  village          String?
  block            String
  district         String
  phone            String
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String            @unique @db.Uuid
  orders           orders[]
  vendor_services  vendor_services[]
  user             User              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("vendors")
}

model Admin {
  admin_level AdminLevel @default(moderator)
  permissions String[]   @default([])
  last_login  DateTime?  @db.Timestamptz(6)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String     @unique @db.Uuid
  user        User       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("admins")
}

model vendor_service_images {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_id      String          @db.Uuid
  url             String
  public_id       String
  is_main         Boolean         @default(false)
  vendor_services vendor_services @relation(fields: [service_id], references: [id], onDelete: Cascade)
}

model vendor_services {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendor_id             String                  @db.Uuid
  service_type          ServiceType
  name                  String
  actual_price          Float
  selling_price         Float
  description           String                  @default("")
  is_active             Boolean                 @default(true)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  main_image            String                  @default("")
  images                String[]                @default([])
  orders                orders[]
  vendor_service_images vendor_service_images[]
  service_ratings       service_ratings[]
  vendors               Vendor                  @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
}

model service_ratings {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_id String          @db.Uuid
  user_id    String          @db.Uuid
  rating     Int
  review     String          @default("")
  created_at DateTime        @default(now()) @db.Timestamptz(6)
  users      User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  vendor_services vendor_services @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@unique([service_id, user_id])
  @@map("service_ratings")
}

model orders {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_id      String          @db.Uuid
  user_id         String          @db.Uuid
  vendor_id       String          @db.Uuid
  event_date      DateTime        @db.Date
  message         String?         @default("")
  status          String          @default("pending")
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime        @default(now()) @db.Timestamptz(6)
  vendor_services vendor_services @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           User            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendors         Vendor          @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum Role {
  user
  vendor
  pandit
  admin
}

enum AdminLevel {
  super_admin
  moderator
}

enum ServiceType {
  DJ
  Catering
  Decoration
  Mehndi
  BhoomiPooja
  GrihaPravesh
  VastuShanti
  VahaanPooja
  DukaanUdghatan
  SatyanarayanKatha
  GaneshChaturthi
  LakshmiPooja
  NavratriPooja
  MahaMrityunjayaJaap
  KundaliMilan
  GrahaShanti
  Rudrabhishek
}
